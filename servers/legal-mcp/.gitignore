# Dependencias
node_modules/

# OJO: build/ NO se ignora. En este repo build/ NO es codigo compilado: es el
# codigo FUENTE de los conectores (los .js viven ahi). Si se ignora, cada conector
# nuevo hay que meterlo con `git add -f`, lo que es facil de olvidar. Los datos
# locales que si van dentro de build/ (perfiles de navegador) se excluyen abajo.

# Datos locales y perfiles de navegador (sesiones/cookies personales)
data/
build/.mev-profile/
build/data/

# Logs y diagnostico
*.log
diagnose*.js
diagnose-output.txt

# Variables de entorno
.env
.env.*

# Sistema operativo
.DS_Store
Thumbs.db
